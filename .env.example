# QPay (Mongolia) Payment Gateway credentials
# Copy this file to .env and fill in your real values.
QPAY_USERNAME=your_qpay_username
QPAY_PASSWORD=your_qpay_password

# Public base URL of this server (used to build the QPay callback URL)
BASE_URL=https://mydomain.com

# Path to the Google service account key file (JSON) used for Calendar API access.
# The service account must be granted access to each stylist's Google Calendar.
# Defaults to credentials.json in the project root if not set.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
